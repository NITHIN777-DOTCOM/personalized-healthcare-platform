# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (SQLite)
# For local SQLite, use a file path (relative or absolute)
DATABASE_URL="file:./dev.db"

# CORS Configuration
# Set this to the production domain of your frontend React client
FRONTEND_URL="http://localhost:3000"

# JWT Secret Keys (Generate cryptographically strong secrets in production)
JWT_ACCESS_SECRET="your-super-secret-access-token-key-should-be-very-long-and-secure"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-should-be-very-long-and-secure"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
